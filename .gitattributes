# Default: normalize all text files to LF
* text=auto eol=lf

# Python / code
*.py text eol=lf
*.js text eol=lf
*.html text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows-specific scripts (keep CRLF if needed)
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files (no conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.db binary